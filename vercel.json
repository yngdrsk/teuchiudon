{
    "buildCommand": "composer install --no-dev && npm run build && php artisan migrate --force",
    "outputDirectory": "public",
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/index.php"
        }
    ],
    "functions": {
        "index.php": {
            "runtime": "vercel-php@0.6.0"
        }
    }
}