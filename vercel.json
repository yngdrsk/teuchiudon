{
    "builds": [
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.4",
            "config": {
                "phpVersion": "8.3"
            }
        }
    ],
    "buildCommand": "composer install --no-dev && npm run build && php artisan migrate --force",
    "outputDirectory": "public",
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ]
}