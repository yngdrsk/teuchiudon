{
    "builds": [
        {
            "src": "public/index.html",
            "use": "@vercel/static-build"
        },
        {
            "src": "api/index.php",
            "use": "vercel-php@0.7.4",
            "config": {
                "phpVersion": "8.3"
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        },
        {
            "src": "/(.*)",
            "dest": "/public/index.html"
        }
    ]
}