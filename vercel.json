{
    "build": {
        "env": {
            "VERCEL_PHP_VERSION": "8.3"
        }
    },
    "buildCommand": "composer install --no-dev && npm run build && php artisan migrate --force",
    "outputDirectory": "public",
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.4"
        }
    }
}